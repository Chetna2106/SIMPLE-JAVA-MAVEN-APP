    agent any  //as we will explicitylt specify agent on differnt steps
    stages {   //below provided all are sequential stages not parallel
        stage('Build') {
            steps {
                echo(message: 'This is Build stage') 
            }
        }
        stage('Test') {
            steps {
                echo(message: 'This is test stage') 
            }
        }
        stage('Deploy') { 
            echo(message: 'This is deployment stage')
        }
    }
}
